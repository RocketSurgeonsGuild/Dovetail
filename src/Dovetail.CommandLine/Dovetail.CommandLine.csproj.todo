<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <PackageDescription>
            Provides the ability to provide additional commands to the hosted
            application by convention.
        </PackageDescription>
        <PackageTags>$(PackageTags);command line;cli;command</PackageTags>
        <NoWarn>$(NoWarn);RCS1102;CA1812</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="..\Dovetail\Dovetail.csproj" />
        <ProjectReference Include="..\Dovetail.Hosting/Dovetail.Hosting.csproj" />

        <ProjectReference
            Include="..\Dovetail.Analyzers\Dovetail.Analyzers.csproj"
            IncludeAssets="analyzers;build;buildMultitargeting;buildTransitive"
            ExcludeAssets="compile;runtime;native"
            PrivateAssets="contentfiles;build;buildMultitargeting;buildTransitive"
            OutputItemType="Analyzer"
            ReferenceOutputAssembly="false"
        />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Spectre.Console" />
        <PackageReference Include="Spectre.Console.Cli" />
        <PackageReference Include="Microsoft.Extensions.Hosting" />
        <PackageReference Include="Microsoft.Extensions.Configuration.FileExtensions" />
        <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
        <InternalsVisibleTo Include="Dovetail.CommandLine.Tests" />
        <InternalsVisibleTo Include="Dovetail.Diagnostics" />
        <InternalsVisibleTo Include="Dovetail.Tests" />
        <InternalsVisibleTo Include="Dovetail.Hosting" />
        <InternalsVisibleTo Include="Dovetail.Hosting.Abstractions" />
        <InternalsVisibleTo Include="Dovetail.Web.Hosting" />
        <InternalsVisibleTo Include="Dovetail.WebAssembly.Hosting" />
        <InternalsVisibleTo Include="Dovetail.WebAssembly.Hosting.Abstractions" />
    </ItemGroup>
    <ItemGroup>
        <Compile Remove="Temp\*.cs" />
        <None Include="CommandLineHostBuilderExtensions.cs" />
        <None Include="Temp\*.cs" />
    </ItemGroup>
</Project>
