<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <PackageDescription>
            Adds helpers to easily bootstrap an application using conventions by
            just using the correct extension method. This adds command line operations, additional
            configuration, logging and service injections by convention.
        </PackageDescription>
        <PackageTags>$(PackageTags);hosting;generic host</PackageTags>
      <RootNamespace>Dovetail.Testing</RootNamespace>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="../../src/Dovetail/Dovetail.csproj" />
    </ItemGroup>
    <ItemGroup>
        <InternalsVisibleTo Include="Aspire.Hosting.Tests" />
        <PackageReference Include="Aspire.Hosting.Testing" />
    </ItemGroup>
    <ItemGroup>
        <DovetailJoint
            Include="Testing"
            Namespace="Dovetail.Testing.Joints"
        />
    </ItemGroup>
</Project>
