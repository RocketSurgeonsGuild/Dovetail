<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <PackageDescription>Provides Serilog support for a Rocket Surgery Application</PackageDescription>
        <PackageTags>$(PackageTags);Serilog</PackageTags>
    </PropertyGroup>
    <ItemGroup>
        <DovetailJoint Include="Serilog" Namespace="Dovetail.Joints" ParameterType="global::Serilog.LoggerConfiguration" ParameterName="loggerConfiguration" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Serilog" />
        <PackageReference Include="Serilog.Extensions.Logging" />
        <ProjectReference Include="..\Dovetail\Dovetail.csproj" />
    </ItemGroup>
</Project>
