<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageDescription>
      Adds support for loading configuration, services, logging, command line
      and more via simple and easy to setup assembly attributes
    </PackageDescription>
    <PackageTags>$(PackageTags);reflection</PackageTags>
    <IsTrimmable>true</IsTrimmable>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <RootNamespace>Dovetail</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Configuration" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Dovetail" />
    <InternalsVisibleTo Include="Dovetail.CommandLine" />
    <InternalsVisibleTo Include="Dovetail.Hosting" />
    <InternalsVisibleTo Include="Dovetail.Hosting.Abstractions" />
    <InternalsVisibleTo Include="Dovetail.Web.Hosting" />
    <InternalsVisibleTo Include="Dovetail.WebAssembly.Hosting" />
    <InternalsVisibleTo Include="Dovetail.WebAssembly.Hosting.Abstractions" />

    <ProjectReference
      Include="..\Dovetail.Analyzers\Dovetail.Analyzers.csproj"
      IncludeAssets="analyzers"
      ExcludeAssets="compile;runtime;native"
      PrivateAssets="contentfiles;build;buildMultitargeting;buildTransitive"
      OutputItemType="Analyzer"
    />
  </ItemGroup>
  <ItemGroup>
    <None Include="build/*.*" Pack="true" PackagePath="build" />
    <None Include="buildMultiTargeting/*.*" Pack="true" PackagePath="buildMultiTargeting" />
    <None Include="buildTransitive/*.*" Pack="true" PackagePath="buildTransitive" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Dovetail.Mermaid" />
    <DovetailJoint Include="Setup" Namespace="Dovetail.Joints" />
    <DovetailJoint Include="Service" Namespace="Dovetail.Joints" ProvideServices="true" BuilderMethodName="ConfigureServices" />
    <DovetailJoint Include="Configuration" Namespace="Dovetail.Joints" ParameterType="global::Microsoft.Extensions.Configuration.IConfigurationBuilder" ParameterName="builder" />
    <DovetailJoint Include="Logging" Namespace="Dovetail.Joints" ParameterType="global::Microsoft.Extensions.Logging.ILoggingBuilder" ParameterName="builder" />
    <DovetailJoint Include="HostCreated" Namespace="Dovetail.Joints" GenericParameter="THost" ParameterType="THost" ParameterName="host" />
  </ItemGroup>
</Project>
