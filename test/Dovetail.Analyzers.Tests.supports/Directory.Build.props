<Project>
    <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />
    <PropertyGroup>
        <_Analyzer_Roslyn_Version_>$(MSBuildProjectName.Replace('Dovetail.Analyzers.Tests.', ''))</_Analyzer_Roslyn_Version_>
        <DefineConstants>$(DefineConstants);$(_Analyzer_Roslyn_Version_.Replace('.', '_').ToUpper())</DefineConstants>
        <BaseOutputPath>bin/$(_Analyzer_Roslyn_Version_)/</BaseOutputPath>
        <BaseIntermediateOutputPath>$(MSBuildThisFileDirectory)obj/$(_Analyzer_Roslyn_Version_)/</BaseIntermediateOutputPath>
        <NoWarn>$(NoWarn);NU1605</NoWarn>
        <RootNamespace>Dovetail.Analyzers.Tests</RootNamespace>
        <TargetFramework>net10.0-browser</TargetFramework>
        <OutputType>Exe</OutputType>
        <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    </PropertyGroup>
    <ItemGroup>
        <Compile Include="../Dovetail.Analyzers.Tests/*.cs" />
    </ItemGroup>
</Project>
