<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="..\..\sample\AspireSample\AspireSample.csproj" />
        <ProjectReference Include="..\..\src\Dovetail.Aspire\Dovetail.Aspire.csproj" />
        <ProjectReference Include="..\..\src\Dovetail.Aspire.Testing\Dovetail.Aspire.Testing.csproj" />
    </ItemGroup>
    <ItemGroup>
        <DovetailHost
            Include="DistributedApplication"
            Namespace="Dovetail.Joints"
            HostBuilderType="global::Aspire.Hosting.IDistributedApplicationBuilder"
            HostBuilderName="builder"
            HostType="global::Aspire.Hosting.DistributedApplication"
            HasBuildExpression="false"
        />
        <DovetailHost
            Include="DistributedApplicationTesting"
            Namespace="Dovetail.Testing.Joints"
            HostBuilderType="global::Aspire.Hosting.Testing.IDistributedApplicationTestingBuilder"
            HostBuilderName="builder"
            HostType="global::Aspire.Hosting.DistributedApplication"
            HasBuildExpression="false"
        />
    </ItemGroup>
</Project>
